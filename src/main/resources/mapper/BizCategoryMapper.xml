<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd" >

<mapper namespace="com.thx.module.admin.mapper.BizCategoryMapper">
	<resultMap id="rm" type="com.thx.module.admin.entity.BizCategory">
		<result property="id" jdbcType="VARCHAR" column="id"/>
		<result property="pid" jdbcType="VARCHAR" column="pid"/>
		<result property="name" jdbcType="VARCHAR" column="name"/>
		<result property="description" jdbcType="VARCHAR" column="description"/>
		<result property="sort" jdbcType="INTEGER" column="sort"/>
		<result property="status" jdbcType="INTEGER" column="status"/>
		<result property="icon" jdbcType="VARCHAR" column="icon"/>
		<result property="createTime" jdbcType="TIMESTAMP" column="create_time"/>
		<result property="updateTime" jdbcType="TIMESTAMP" column="update_time"/>
		<!-- 父分类的嵌套查询 -->
		<association property="parent" javaType="com.thx.module.admin.entity.BizCategory" select="selectParent" column="pid">
		</association>
		<!--<association property="parent" javaType="com.thx.module.admin.entity.BizCategory">-->
		<!--	<result property="id" jdbcType="INTEGER" column="p_id"/>-->
		<!--	<result property="pid" jdbcType="INTEGER" column="p_pid"/>-->
		<!--	<result property="name" jdbcType="VARCHAR" column="p_name"/>-->
		<!--	<result property="description" jdbcType="VARCHAR" column="p_description"/>-->
		<!--	<result property="status" jdbcType="INTEGER" column="p_status"/>-->
		<!--	<result property="icon" jdbcType="VARCHAR" column="p_icon"/>-->
		<!--</association>-->
		<!-- 子分类的嵌套查询 -->
		<collection property="children" ofType="com.thx.module.admin.entity.BizCategory" select="selectChildren" column="id">
		</collection>
		<!--<collection property="children" column="n_id" javaType="ArrayList" ofType="com.thx.module.admin.entity.BizCategory">-->
		<!--	<result property="id" jdbcType="INTEGER" column="n_id"/>-->
		<!--	<result property="pid" jdbcType="INTEGER" column="n_pid"/>-->
		<!--	<result property="name" jdbcType="VARCHAR" column="n_name"/>-->
		<!--	<result property="description" jdbcType="VARCHAR" column="n_description"/>-->
		<!--	<result property="status" jdbcType="INTEGER" column="n_status"/>-->
		<!--	<result property="icon" jdbcType="VARCHAR" column="n_icon"/>-->
		<!--</collection>-->
	</resultMap>
	<select id="selectParent" parameterType="string" resultType="com.thx.module.admin.entity.BizCategory">
		SELECT * FROM biz_category WHERE id = #{id}
	</select>
	<select id="selectChildren" parameterType="string" resultType="com.thx.module.admin.entity.BizCategory">
		SELECT * FROM biz_category WHERE pid = #{id} ORDER BY sort ASC
	</select>

	<sql id="Base_Column_List">
		id,
		pid,
		name,
		description,
		sort,
		status,
		icon,
		create_time,
		update_time
	</sql>

	<select id="selectCategories" parameterType="com.thx.module.admin.entity.BizCategory" resultMap="rm" >
		select t.*
	<!--p.id p_id,
		p.`pid` p_pid,
		p.`name` p_name,
		p.description p_description,
		p.`status` p_status,
		p.icon p_icon,
		n.`id` n_id,
		n.`pid` n_pid,
		n.`name` n_name,
		n.description n_description,
		n.`status` n_status,
		n.icon n_icon -->
		FROM
		biz_category t
	<!--LEFT JOIN biz_category p ON t.pid = p.id
 		LEFT JOIN biz_category n ON n.pid = t.id -->
		WHERE 1=1
		<if test="name !=null and name != ''">
			AND t.`name` like concat('%', #{name}, '%')
		</if>
		<if test="description !=null and description != ''">
			AND t.description like concat('%', #{description}, '%')
		</if>
		<if test="status !=null">
			AND t.`status` = #{status}
		</if>
		<if test="pid !=null">
			AND t.pid = #{pid}
		</if>
		ORDER BY t.sort ASC
	</select>


	<delete id="deleteBatch" parameterType="map">
		DELETE FROM
		biz_category
		where
		id in
		<foreach collection="array" item="item" index="index" open="(" separator="," close=")">
			#{item}
		</foreach>
	</delete>

	<select id="getById" parameterType="string" resultMap="rm">
		select a.*,
		p.pid p_pid,
		p.`name` p_name,
		p.description p_description
		from biz_category a
		LEFT JOIN biz_category p ON a.pid = p.id
		WHERE a.id=#{id}
	</select>
</mapper>

