# CMS Docker 环境变量配置
# 复制此文件为 .env 并修改敏感信息

# MySQL 配置
SPRING_DATASOURCE_URL=jdbc:mysql://localhost:3306/cms?useUnicode=true&characterEncoding=UTF-8&useSSL=false&serverTimezone=GMT%2B8&allowPublicKeyRetrieval=true
SPRING_DATASOURCE_USERNAME=
SPRING_DATASOURCE_PASSWORD=

# Redis 配置
SPRING_REDIS_HOST=localhost
SPRING_REDIS_PORT=6379
SPRING_REDIS_PASSWORD=

# Mail 配置
SPRING_MAIL_USERNAME=
SPRING_MAIL_PASSWORD=

# Agent API 配置（可选）
AGENT_API_KEY=

# Shiro rememberMe AES key, Base64 encoded 16/24/32 bytes.
SHIRO_REMEMBER_ME_CIPHER_KEY=

# minio 配置
# App 的 API Key 现在保存在 file_app.api_key_hash（SHA-256 哈希），Bucket 由 file_policy 表配置，
# 均不再通过环境变量下发，见 docs/db/file_system.sql
MINIO_ENDPOINT=
MINIO_ACCESS_KEY=
MINIO_SECRET_KEY=
MINIO_PUBLIC_DOMAIN=

# Druid 监控页面配置
DRUID_STAT_USERNAME=druid
DRUID_STAT_PASSWORD=

# 支付模块配置
# 渠道配置（如支付宝私钥）AES-GCM 加密主密钥，Base64 编码 16/24/32 字节，生成示例：openssl rand -base64 32
# 禁止写入代码仓库、禁止落库，只能通过环境变量下发；轮换需要重新加密全部 payment_channel_account.config_encrypted
PAYMENT_MASTER_KEY=
# 支付宝服务器能访问到的公网回调地址，如 https://cms.thxdxw.cn（不能填内网/容器内地址）
PAYMENT_PUBLIC_BASE_URL=