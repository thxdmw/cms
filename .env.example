# CMS Docker 环境变量配置
# 复制此文件为 .env 并修改敏感信息

# MySQL 配置
SPRING_DATASOURCE_URL=jdbc:mysql://localhost:3306/cms?useUnicode=true&characterEncoding=UTF-8&useSSL=false&serverTimezone=GMT%2B8&allowPublicKeyRetrieval=true
SPRING_DATASOURCE_USERNAME=
SPRING_DATASOURCE_PASSWORD=

# Redis 配置
SPRING_REDIS_HOST=localhost
SPRING_REDIS_PORT=6379
SPRING_REDIS_PASSWORD=

# Mail 配置
SPRING_MAIL_USERNAME=
SPRING_MAIL_PASSWORD=

# Agent API 配置（可选）
AGENT_API_KEY=

# minio 配置
# App 的 API Key 现在保存在 file_app.api_key_hash（SHA-256 哈希），Bucket 由 file_policy 表配置，
# 均不再通过环境变量下发，见 docs/db/file_system.sql
MINIO_ENDPOINT=
MINIO_ACCESS_KEY=
MINIO_SECRET_KEY=
MINIO_PUBLIC_DOMAIN=

# Druid 监控页面配置
DRUID_STAT_USERNAME=druid
DRUID_STAT_PASSWORD=